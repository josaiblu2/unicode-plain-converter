---
// ConversionWidget.astro
---

<div class="flex flex-col gap-8 w-full">
    
    <!-- Top Area (Input) -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden flex flex-col transition-shadow hover:shadow-md">
        <div class="bg-slate-50 px-4 py-3 border-b border-slate-200 flex items-center justify-between">
            <span class="text-xs font-bold text-slate-500 uppercase tracking-widest" id="top-label">Plain Text</span>
            
            <button id="clear-btn" class="text-slate-400 hover:text-slate-600 transition-colors" title="Clear Text" aria-label="Clear Text">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
        </div>
        <textarea id="input-text" class="w-full min-h-[180px] p-4 bg-transparent resize-y outline-none text-lg text-slate-800 placeholder-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-500/50" placeholder="Type or paste your text here..."></textarea>
    </div>

    <!-- Central Controls -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative z-10 w-full px-4">
        
        <select id="style-selector" class="w-full sm:w-auto bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none cursor-pointer hover:bg-slate-50 shadow-sm transition">
            <option value="bold">Bold</option>
            <option value="italic">Italic</option>
            <option value="script">Script</option>
            <option value="fraktur">Fraktur</option>
            <option value="monospace">Monospace</option>
            <option value="double_struck">Double-Struck</option>
        </select>

        <button id="swap-btn" class="flex-shrink-0 w-12 h-12 bg-blue-600 hover:bg-blue-700 text-white rounded-full shadow-md flex items-center justify-center transition-all hover:scale-105 active:scale-95 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" aria-label="Swap Conversion Direction" title="Swap Direction">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-90 sm:rotate-0"><path d="m16 3-4 4 4 4"/><path d="M20 7H4"/><path d="m8 21 4-4-4-4"/><path d="M4 17h16"/></svg>
        </button>

        <button id="copy-btn" class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium shadow-md transition-all active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            <span id="copy-text">Copy Result</span>
        </button>

    </div>

    <!-- Bottom Area (Output) -->
    <div class="bg-slate-50 border border-slate-200 rounded-xl shadow-sm overflow-hidden flex flex-col relative transition-shadow hover:shadow-md">
        <div class="bg-slate-100 px-4 py-3 border-b border-slate-200 flex items-center justify-between">
            <span class="text-xs font-bold text-blue-600 uppercase tracking-widest" id="bottom-label">Unicode Style</span>
            
            <!-- Loader indicator (small spinner) -->
            <div id="loader" class="hidden items-center gap-2 text-xs font-medium text-slate-500 animate-pulse">
               <div class="w-3 h-3 border-2 border-slate-400 border-t-transparent rounded-full animate-spin"></div>
               Converting...
            </div>
        </div>
        
        <textarea id="output-text" class="w-full min-h-[180px] p-4 bg-transparent resize-y outline-none text-lg text-slate-800 font-medium placeholder-slate-400" readonly placeholder="Result will appear here..."></textarea>
    </div>
</div>

<script>
    // Component State & Logic
    let direction = 'to_unicode'; // or 'to_plain'
    let currentStyle = 'bold';
    let timeoutId = null;

    // DOM Elements
    const inputEl = document.getElementById('input-text') as HTMLTextAreaElement;
    const outputEl = document.getElementById('output-text') as HTMLTextAreaElement;
    const swapBtn = document.getElementById('swap-btn');
    const copyBtn = document.getElementById('copy-btn');
    const clearBtn = document.getElementById('clear-btn');
    const copyText = document.getElementById('copy-text');
    const styleSelector = document.getElementById('style-selector') as HTMLSelectElement;
    const topLabel = document.getElementById('top-label');
    const bottomLabel = document.getElementById('bottom-label');
    const loader = document.getElementById('loader');

    const updateLabels = () => {
        if (direction === 'to_unicode') {
            topLabel.textContent = 'Plain Text';
            topLabel.className = 'text-xs font-bold text-slate-500 uppercase tracking-widest';
            
            bottomLabel.textContent = 'Unicode Style';
            bottomLabel.className = 'text-xs font-bold text-blue-600 uppercase tracking-widest';
            
            styleSelector.disabled = false;
            styleSelector.classList.remove('opacity-50', 'cursor-not-allowed');
        } else {
            topLabel.textContent = 'Unicode Style';
            topLabel.className = 'text-xs font-bold text-blue-600 uppercase tracking-widest';
            
            bottomLabel.textContent = 'Plain Text';
            bottomLabel.className = 'text-xs font-bold text-slate-500 uppercase tracking-widest';
            
            // Disable style selector when converting back to plain text
            styleSelector.disabled = true;
            styleSelector.classList.add('opacity-50', 'cursor-not-allowed');
        }
    };

    const handleSwap = () => {
        direction = direction === 'to_unicode' ? 'to_plain' : 'to_unicode';
        updateLabels();
        
        // Swap contents
        const temp = inputEl.value;
        inputEl.value = outputEl.value;
        
        // Trigger conversion based on new state
        if (inputEl.value.trim().length > 0) {
            convertText(inputEl.value);
        } else {
            outputEl.value = '';
        }
    };

    const handleClear = () => {
        inputEl.value = '';
        outputEl.value = '';
        inputEl.focus();
    };

    const handleCopy = async () => {
        const text = outputEl.value;
        if (!text) return;
        
        try {
            await navigator.clipboard.writeText(text);
            const originalText = copyText.textContent;
            copyText.textContent = 'Copied!';
            copyBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
            copyBtn.classList.add('bg-green-600', 'hover:bg-green-700');
            
            setTimeout(() => {
                copyText.textContent = originalText;
                copyBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
                copyBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
            }, 2000);
        } catch (err) {
            console.error('Failed to copy', err);
        }
    };

    const convertText = async (text: string) => {
        if (!text.trim()) {
            outputEl.value = '';
            return;
        }

        loader.classList.remove('hidden');
        loader.classList.add('flex');

        try {
            const payload = {
                text: text,
                conversion_type: direction,
                target_style: direction === 'to_unicode' ? currentStyle : null
            };

            const response = await fetch('http://localhost:8001/convert', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                throw new Error(`API Error: ${response.status}`);
            }

            const data = await response.json();
            outputEl.value = data.converted_text;
        } catch (error) {
            console.error("Conversion failed:", error);
            outputEl.value = "Error connecting to the conversion server.";
        } finally {
            loader.classList.add('hidden');
            loader.classList.remove('flex');
        }
    };

    // Event Listeners
    swapBtn?.addEventListener('click', handleSwap);
    copyBtn?.addEventListener('click', handleCopy);
    clearBtn?.addEventListener('click', handleClear);
    
    styleSelector.addEventListener('change', (e) => {
        const target = e.target as HTMLSelectElement;
        currentStyle = target.value;
        if (inputEl.value && direction === 'to_unicode') {
            convertText(inputEl.value);
        }
    });

    // Debounce the input to avoid hammering the API
    inputEl.addEventListener('input', (e) => {
        const target = e.target as HTMLTextAreaElement;
        if (timeoutId) clearTimeout(timeoutId);
        
        timeoutId = setTimeout(() => {
            convertText(target.value);
        }, 300);
    });

</script>
