---
import '../styles/global.css';
import ConversionWidget from '../components/ConversionWidget.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unicode Converter | Professional Text Formatter</title>
    <meta name="description" content="A fast, secure SaaS platform to perfectly convert styled Unicode back into plain text, or standard text into mathematical alphanumeric symbols.">
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-white text-slate-900 font-sans min-h-screen selection:bg-blue-600 selection:text-white antialiased flex flex-col">
    
    <header class="border-b border-slate-200 bg-white/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center font-bold text-white shadow-sm">U</div>
                <span class="font-bold text-xl tracking-tight text-slate-900">Unicode<span class="text-blue-600">Converter</span></span>
            </div>
            <nav class="hidden md:flex gap-6 text-sm font-semibold text-slate-600">
                <a href="#" class="hover:text-blue-600 transition-colors">Documentation</a>
                <a href="#" class="hover:text-blue-600 transition-colors">API Reference</a>
                <a href="https://github.com/josaiblu2/unicode-plain-converter" target="_blank" class="hover:text-blue-600 transition-colors">GitHub</a>
            </nav>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-12 flex-1 w-full">
        <div class="text-center mb-12">
            <h1 class="text-5xl font-bold tracking-tight mb-6 text-slate-900">
                Transform Typography Instantly
            </h1>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
                Bidirectional conversion between mathematical alphanumeric variations and standard text. Built for speed, precision, and automation.
            </p>
        </div>

        <section aria-label="Conversion Tool" class="w-full">
            <ConversionWidget />
        </section>
    </main>

    <footer class="mt-auto border-t border-slate-200 bg-slate-50 py-6 text-center text-sm text-slate-500">
        <div class="max-w-4xl mx-auto px-4">
            <p>&copy; {new Date().getFullYear()} Unicode Converter SaaS. Monorepo Architecture.</p>
        </div>
    </footer>
</body>
</html>

<style>
    body {
        font-family: 'Inter', sans-serif;
    }
</style>
